# Server
PORT=3000
BIND_HOST=0.0.0.0
NODE_ENV=development

# Canonical URL for operators (logged at startup, surfaced on /health).
# Has no effect on routing — change DNS / hosts / Tailscale to actually route.
PUBLIC_BASE_URL=http://airelay.local:3000

# Timezone — always UTC; do not change
TZ=UTC

# Logging
LOG_DIR=./data/logs
LOG_RETENTION_DAYS=7
MAX_LOG_SIZE_MB=50
LOG_LEVEL=info
LOG_SINK=file  # file | stdout | noop

# Log rotation (cron expression, UTC)
CRON_SCHEDULE=0 0 * * *

# SSE keep-alive ping interval (ms)
SSE_HEARTBEAT_MS=30000

# Future: gzip rotated logs
ENABLE_COMPRESSION=false

# ─────────────────────────────────────────────────────────────
# Proxy
# ─────────────────────────────────────────────────────────────
# Upstream the proxy forwards to. Leave blank to disable proxy.
# Provider-agnostic — anything that speaks HTTPS over a single host works.
#
# Examples:
#   Anthropic           UPSTREAM_URL=https://api.anthropic.com
#   OpenAI              UPSTREAM_URL=https://api.openai.com/v1
#   Google Gemini       UPSTREAM_URL=https://generativelanguage.googleapis.com
#   OpenRouter          UPSTREAM_URL=https://openrouter.ai/api/v1
#   Self-hosted (HTTP)  UPSTREAM_URL=http://upstream-service:8080
#
# NOT compatible: AWS Bedrock and other SigV4-signed APIs — the signature is
# bound to the original Host header, which this proxy rewrites (changeOrigin).
UPSTREAM_URL=

# Path prefix; requests to <PROXY_PATH_PREFIX>/* are proxied.
PROXY_PATH_PREFIX=/proxy

# Set to true to add X-Forwarded-* headers (technically a modification — opt-in).
PROXY_TRUST_FORWARDED=false

# Skip TLS cert verification on the upstream connection. Default false — real
# AI providers have valid certs. Set true ONLY for self-signed dev upstreams.
PROXY_INSECURE_TLS=false

# ─────────────────────────────────────────────────────────────
# Metrics
# ─────────────────────────────────────────────────────────────
# Ring buffer size — older events are overwritten.
MAX_METRIC_EVENTS=10000

# Aggregator tick / SSE broadcast cadence.
METRICS_TICK_MS=1000

# ─────────────────────────────────────────────────────────────
# SSE limits (protect against fd exhaustion / slow consumers)
# ─────────────────────────────────────────────────────────────
MAX_SSE_CLIENTS=50
SSE_EVENT_RATE=50

# ─────────────────────────────────────────────────────────────
# Shutdown
# ─────────────────────────────────────────────────────────────
SHUTDOWN_TIMEOUT_MS=30000

# ─────────────────────────────────────────────────────────────
# Token & Cost Tracking (v0.2.0)
# ─────────────────────────────────────────────────────────────
# One of: anthropic openai google mistral groq microsoft openrouter
#         together fireworks deepseek xai perplexity ollama nvidia anlinkai
#         cerebras generic
#
# IMPORTANT: this name is also the pricing key in config/pricing.json. Pick the
# provider that owns the model — NOT the wire format. Mistral and Groq speak the
# OpenAI schema but their models are priced under "mistral" / "groq". Setting
# PROXY_PROVIDER=openai for a Mistral upstream extracts tokens fine but reports
# costUsd=0 (no openai→mistral-* entry exists).
PROXY_PROVIDER=generic

# Set false to disable body inspection entirely (v0.1 zero-overhead behavior)
PROXY_TOKEN_TRACKING=true

# Optional path to custom pricing JSON (deep-merged over bundled defaults)
# PRICING_CONFIG_PATH=/path/to/my-pricing.json

# Per-request cap on bytes buffered for token extraction. Responses exceeding
# this size abandon the tee (extraction skipped, base event still recorded).
# Default 2 MiB — enough for typical JSON responses, prevents large SSE streams
# from pinning memory.
PROXY_TOKEN_TEE_MAX_BYTES=2097152

# ─────────────────────────────────────────────────────────────
# Compactor (v0.3.0) — opt-in prompt/response compression
# ─────────────────────────────────────────────────────────────
# Master switch. Default false: AIRelay remains a pure passthrough — single
# boolean check on the hot path, byte-identical forwarding. Set true to
# enable per-request body compression through the deterministic pipeline.
# See docs/COMPACTOR.md for the full feature reference.
COMPACTOR_ENABLED=false

# Scope toggles (only meaningful when master switch is on).
COMPACTOR_REQUEST_BODY=true        # compress prompts sent upstream
COMPACTOR_RESPONSE_BODY=false      # compress responses (v2 — currently inert)
COMPACTOR_TOOL_RESULT_ONLY=true    # only mutate tool_result/role:tool blocks

# Risky compressors (those that may drop user-needed content) are off unless
# this is true. Currently only long-file-elide is risky.
COMPACTOR_ALLOW_RISKY=false

# Per-compressor toggles. Default true; set false to drop one from the pipeline.
COMPACTOR_ANSI_STRIP_ENABLED=true
COMPACTOR_BLANKLINE_COLLAPSE_ENABLED=true
COMPACTOR_DIFF_COLLAPSE_ENABLED=true
COMPACTOR_LOCKFILE_DROP_ENABLED=true
COMPACTOR_LS_LONG_SHRINK_ENABLED=true
COMPACTOR_NPM_NOISE_STRIP_ENABLED=true
COMPACTOR_REPEAT_LINE_DEDUPE_ENABLED=true
COMPACTOR_STACKTRACE_DEDUPE_ENABLED=true
COMPACTOR_LONG_FILE_ELIDE_ENABLED=true
COMPACTOR_BASE64_TRUNCATE_ENABLED=true

# Buffering cap. Requests exceeding this size respond 413 instead of silently
# bypassing — operator chooses between "compress everything ≤ cap" and "always
# pass through". Default 4 MiB.
COMPACTOR_MAX_REQ_BYTES=4194304

# Line threshold above which long-file-elide considers a segment "long".
COMPACTOR_LONG_FILE_THRESHOLD=400

# ─────────────────────────────────────────────────────────────
# Guardrails (v0.4.0) — opt-in prompt safety: secrets, PII, injection
# ─────────────────────────────────────────────────────────────
# Master switch. Default false: byte-identical passthrough, no detection.
# When true, JSON request bodies POSTed under PROXY_PATH_PREFIX are inspected
# for matches according to the per-category mode below.
# See docs/GUARDRAILS.md for the full feature reference.
GUARDRAILS_ENABLED=false

# Buffering cap. Requests over this size respond 413 when any category is
# active (block/redact require buffering; alert also buffers in v1).
GUARDRAILS_MAX_REQ_BYTES=4194304

# Per-category mode: off | alert | block | redact
#   off    — detector not run
#   alert  — detect + record, forward unchanged
#   block  — detect + reject with 4xx, do not forward
#   redact — detect + replace match with <redacted:NAME>, forward modified
GUARDRAILS_SECRETS_MODE=off
GUARDRAILS_PII_MODE=off
GUARDRAILS_INJECTION_MODE=off

# Per-detector enable (only consulted when the category mode != off).
GUARDRAILS_AWS_ACCESS_KEY_ENABLED=true
GUARDRAILS_GITHUB_PAT_ENABLED=true
GUARDRAILS_ANTHROPIC_KEY_ENABLED=true
GUARDRAILS_OPENAI_KEY_ENABLED=true
GUARDRAILS_PRIVATE_KEY_ENABLED=true
GUARDRAILS_JWT_ENABLED=true
GUARDRAILS_GENERIC_HIGH_ENTROPY_ENABLED=false
GUARDRAILS_EMAIL_ENABLED=true
GUARDRAILS_PHONE_ENABLED=true
GUARDRAILS_SSN_ENABLED=false
GUARDRAILS_CREDIT_CARD_ENABLED=true
GUARDRAILS_ROLE_OVERRIDE_ENABLED=true
GUARDRAILS_SYSTEM_PROMPT_LEAK_ENABLED=true
GUARDRAILS_TOOL_OVERRIDE_ENABLED=true

# Optional: path to a JSON file with custom patterns.
# File shape: [{ "name": "my-secret", "category": "secrets", "regex": "FOO_[A-Z0-9]{20}", "risky": false }]
# GUARDRAILS_CUSTOM_PATTERNS_FILE=/path/to/patterns.json
