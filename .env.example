# Server
PORT=3000
BIND_HOST=0.0.0.0
NODE_ENV=development

# Canonical URL for operators (logged at startup, surfaced on /health).
# Has no effect on routing — change DNS / hosts / Tailscale to actually route.
PUBLIC_BASE_URL=http://airelay.local:3000

# Timezone — always UTC; do not change
TZ=UTC

# Logging
LOG_DIR=./data/logs
LOG_RETENTION_DAYS=7
MAX_LOG_SIZE_MB=50
LOG_LEVEL=info
LOG_SINK=file  # file | stdout | noop

# Log rotation (cron expression, UTC)
CRON_SCHEDULE=0 0 * * *

# SSE keep-alive ping interval (ms)
SSE_HEARTBEAT_MS=30000

# Future: gzip rotated logs
ENABLE_COMPRESSION=false

# ─────────────────────────────────────────────────────────────
# Proxy
# ─────────────────────────────────────────────────────────────
# Upstream the proxy forwards to. Leave blank to disable proxy.
# Provider-agnostic — anything that speaks HTTPS over a single host works.
#
# Examples:
#   Anthropic           UPSTREAM_URL=https://api.anthropic.com
#   OpenAI              UPSTREAM_URL=https://api.openai.com/v1
#   Google Gemini       UPSTREAM_URL=https://generativelanguage.googleapis.com
#   OpenRouter          UPSTREAM_URL=https://openrouter.ai/api/v1
#   Self-hosted (HTTP)  UPSTREAM_URL=http://upstream-service:8080
#
# NOT compatible: AWS Bedrock and other SigV4-signed APIs — the signature is
# bound to the original Host header, which this proxy rewrites (changeOrigin).
UPSTREAM_URL=

# Path prefix; requests to <PROXY_PATH_PREFIX>/* are proxied.
PROXY_PATH_PREFIX=/proxy

# Set to true to add X-Forwarded-* headers (technically a modification — opt-in).
PROXY_TRUST_FORWARDED=false

# Skip TLS cert verification on the upstream connection. Default false — real
# AI providers have valid certs. Set true ONLY for self-signed dev upstreams.
PROXY_INSECURE_TLS=false

# ─────────────────────────────────────────────────────────────
# Metrics
# ─────────────────────────────────────────────────────────────
# Ring buffer size — older events are overwritten.
MAX_METRIC_EVENTS=10000

# Aggregator tick / SSE broadcast cadence.
METRICS_TICK_MS=1000

# ─────────────────────────────────────────────────────────────
# SSE limits (protect against fd exhaustion / slow consumers)
# ─────────────────────────────────────────────────────────────
MAX_SSE_CLIENTS=50
SSE_EVENT_RATE=50

# ─────────────────────────────────────────────────────────────
# Shutdown
# ─────────────────────────────────────────────────────────────
SHUTDOWN_TIMEOUT_MS=30000

# ─────────────────────────────────────────────────────────────
# Token & Cost Tracking (v0.2.0)
# ─────────────────────────────────────────────────────────────
# One of: anthropic openai google mistral groq microsoft openrouter
#         together fireworks deepseek xai perplexity ollama nvidia anlinkai
#         generic
#
# IMPORTANT: this name is also the pricing key in config/pricing.json. Pick the
# provider that owns the model — NOT the wire format. Mistral and Groq speak the
# OpenAI schema but their models are priced under "mistral" / "groq". Setting
# PROXY_PROVIDER=openai for a Mistral upstream extracts tokens fine but reports
# costUsd=0 (no openai→mistral-* entry exists).
PROXY_PROVIDER=generic

# Set false to disable body inspection entirely (v0.1 zero-overhead behavior)
PROXY_TOKEN_TRACKING=true

# Optional path to custom pricing JSON (deep-merged over bundled defaults)
# PRICING_CONFIG_PATH=/path/to/my-pricing.json

# Per-request cap on bytes buffered for token extraction. Responses exceeding
# this size abandon the tee (extraction skipped, base event still recorded).
# Default 2 MiB — enough for typical JSON responses, prevents large SSE streams
# from pinning memory.
PROXY_TOKEN_TEE_MAX_BYTES=2097152
