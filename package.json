{
  "name": "airelay",
  "version": "0.2.0",
  "description": "AIRelay — transparent passthrough proxy for AI/LLM HTTP APIs with live observability dashboard",
  "type": "module",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "start": "node src/index.js",
    "dev": "node --watch src/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src/ tests/ && prettier --check src/ tests/ public/",
    "lint:fix": "eslint src/ tests/ --fix && prettier --write src/ tests/ public/",
    "docker:build": "docker build -f docker/Dockerfile -t airelay .",
    "docker:up": "docker compose up --build",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f app"
  },
  "dependencies": {
    "express": "^4.21.2",
    "http-proxy": "^1.18.1",
    "node-cron": "^3.0.3"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^3.1.2",
    "dotenv": "^16.5.0",
    "eslint": "^9.25.1",
    "eslint-config-prettier": "^10.1.2",
    "prettier": "^3.5.3",
    "supertest": "^7.1.0",
    "vitest": "^3.1.2"
  }
}
